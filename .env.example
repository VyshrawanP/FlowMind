# =========================================================================
# FlowMind Local & Production Environment Configuration Template
# =========================================================================
# Copy this file to '.env' at the workspace root and fill in real values.
# Docker Compose and Render configurations will automatically parse these keys.

# 1. Server Mode
NODE_ENV=production
PORT=3001

# 2. Database & Cache Connection Strings
# (Defaults map to Docker Compose services)
DATABASE_URL=postgresql://flowmind_user:flowmind_password@postgres:5432/flowmind_db?schema=public
REDIS_URL=redis://redis:6379

# 3. Security Credentials (CRITICAL for Production)
# Define a long, random key to sign JWT sessions (e.g. openssl rand -base64 32)
JWT_SECRET=your-randomly-generated-secure-key-phrase-here

# 4. AI & Integration Credentials (Optional)
# Acquire key from https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
# Personal access token to avoid rate limits on public GitHub repository scans
GITHUB_TOKEN=your-github-personal-access-token-here

# 5. SMTP Mail Delivery Configuration (For Direct OTP email delivery)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-registered-domain.com
SMTP_PASS=your-secure-smtp-password-here
SMTP_FROM="FlowMind Security <noreply@flowmind.com>"
